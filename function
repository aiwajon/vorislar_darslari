# 🔁 19–24: While sikli
def sum_to_n(n):
    total = 0
    i = 1
    while i <= n:
        total += i
        i += 1
    return total

def factorial(n):
    result = 1
    i = 1
    while i <= n:
        result *= i
        i += 1
    return result

def count_digits(n):
    return len(str(abs(n)))

def reverse_number(n):
    reversed_n = 0
    negative = n < 0
    n = abs(n)
    while n != 0:
        reversed_n = reversed_n * 10 + n % 10
        n //= 10
    return -reversed_n if negative else reversed_n

def sum_of_digits(n):
    n = abs(n)
    total = 0
    while n != 0:
        total += n % 10
        n //= 10
    return total

def multiplication_table(n):
    table = []
    i = 1
    while i <= 10:
        table.append(f"{n} x {i} = {n*i}")
        i += 1
    return table


